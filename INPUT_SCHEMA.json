{
  "title": "Indeed Jobs Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "searches": {
      "title": "Searches",
      "type": "array",
      "description": "Array of Indeed searches to run",
      "editor": "json",
      "prefill": [
        {
          "query": "production operator",
          "location": "united states",
          "fromDays": 1,
          "maxResults": 20
        }
      ],
      "items": {
        "type": "object",
        "title": "Search",
        "properties": {
          "query": {
            "title": "Query",
            "type": "string"
          },
          "location": {
            "title": "Location",
            "type": "string"
          },
          "fromDays": {
            "title": "Posted within days",
            "type": "integer",
            "minimum": 0,
            "default": 1
          },
          "maxResults": {
            "title": "Max results",
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        },
        "required": [
          "query"
        ]
      }
    },
    "maxConcurrency": {
      "title": "Max concurrency",
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "default": 5
    },
    "includeCompanyInfo": {
      "title": "Include company info",
      "type": "boolean",
      "default": true
    },
    "proxyUrl": {
      "title": "Proxy URL",
      "type": "string",
      "description": "Optional proxy URL. Example: http://auto:PROXY_PASSWORD@proxy.apify.com:8000"
    }
  },
  "required": [
    "searches"
  ]
}
